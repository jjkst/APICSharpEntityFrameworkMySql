# Environment Variables Template
# Copy this file to .env.local for development
# Copy to .env.production for production deployment

# Database Configuration
CONNECTIONSTRING="Server=localhost;Database=RukuITServices;User=root;Password=your-password;"

# Email Configuration
SMTP_SERVER="smtp.XXXXX.com"
SMTP_PORT="XXX"
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
ENABLE_SSL="true"
RECIPIENT_EMAIL="your-recipient@gmail.com"

# JWT Configuration
JWT_SECRET_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
JWT_ISSUER="RukuServiceApi"
JWT_AUDIENCE="RukuServiceApiUsers"
JWT_EXPIRATION_MINUTES="60"

# Application Configuration
# Use semicolons to separate multiple hosts
ALLOWED_HOSTS="localhost;127.0.0.1;your-domain.com"
